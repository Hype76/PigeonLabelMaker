{
  "name": "pigeon-label-maker",
  "version": "1.1.6",
  "private": true,
  "author": "Pigeon Label Maker",
  "description": "Electron shell for the Pigeon Label Maker Python backend",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron ./electron/main.js",
    "electron": "electron ./electron/main.js",
    "build:backend": "python -m PyInstaller --clean --noconfirm --onefile --name backend --distpath python-dist --workpath build/pyinstaller --specpath build/pyinstaller backend_entry.py",
    "build": "npm run build:backend && electron-builder",
    "release": "npm run build:backend && electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.pigeon.labelmaker",
    "productName": "Pigeon Label Maker",
    "electronLanguages": [
      "en-US",
      "en-GB"
    ],
    "directories": {
      "output": "dist"
    },
    "artifactName": "Pigeon-Label-Maker-Setup-${version}.${ext}",
    "files": [
      "electron/**/*",
      "pigeon_label_maker/**/*",
      "requirements.txt",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python-dist",
        "to": "python"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "icon": "electron/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Hype76",
        "repo": "PigeonLabelMaker"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4"
  }
}
